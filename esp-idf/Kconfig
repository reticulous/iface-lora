menu "spangap: reticulous iface-lora"

config LORA_COUNT
    int "Number of LoRa radios"
    range 0 4
    default 0
    help
        How many LoRa modems this board drives. 0 means no LoRa: iface-lora
        compiles to a no-op (loraInit() returns immediately, RadioLib is
        linked out). Each radio registers with the transport daemon as a
        separate interface named lora/<slot> (lora/0, lora/1, ...).

        Boards set this (and the pins below) in their sdkconfig.defaults;
        a build can override with `spangap build --lora-count N` and the
        matching --loraN-* switches, or interactively via `spangap menuconfig`.

# ─── shared SPI bus ───────────────────────────────────────────────────
# One SPI host carries every radio (and, on boards like the T-Deck, the
# display and SD card too). spi_helper makes bus bring-up idempotent, so
# all radios share these pins; only CS/DIO1/BUSY/RST differ per radio.

config LORA_SPI_HOST
    int "Shared SPI host (1=SPI1 2=SPI2/FSPI 3=SPI3)"
    default 2
    depends on LORA_COUNT > 0

config LORA_SCK_PIN
    int "SPI SCK pin"
    default -1
    depends on LORA_COUNT > 0

config LORA_MOSI_PIN
    int "SPI MOSI pin"
    default -1
    depends on LORA_COUNT > 0

config LORA_MISO_PIN
    int "SPI MISO pin"
    default -1
    depends on LORA_COUNT > 0

# ─── radio 0 ──────────────────────────────────────────────
config LORA0_CS_PIN
    int "Radio 0 — CS / NSS pin"
    default -1
    depends on LORA_COUNT > 0
config LORA0_DIO1_PIN
    int "Radio 0 — IRQ pin"
    default -1
    depends on LORA_COUNT > 0
    help
        The chip's interrupt line wired to this MCU GPIO: DIO1 on SX126x/
        SX128x, DIO0 on SX127x, IRQ on LR11x0/LR2021. RX-done wakes the task.
config LORA0_BUSY_PIN
    int "Radio 0 — BUSY pin (-1 if none)"
    default -1
    depends on LORA_COUNT > 0
    help
        SX126x/SX128x/LR11x0/LR2021 have a BUSY line; SX127x does not — set -1.
config LORA0_RST_PIN
    int "Radio 0 — RST pin (-1 if none)"
    default -1
    depends on LORA_COUNT > 0
config LORA0_TCXO_MV
    int "Radio 0 — TCXO control voltage in mV (0 = no TCXO / XTAL)"
    default 0
    depends on LORA_COUNT > 0
    help
        Applies to SX126x / LR11x0 / LR2021 (chip-driven TCXO). Ignored by
        SX127x (crystal only) and SX128x (hardware XTAL/TCXO).
config LORA0_DIO2_RF_SWITCH
    bool "Radio 0 — DIO2 drives the RF switch (SX126x only)"
    default n
    depends on LORA_COUNT > 0
config LORA0_RFSW_RX_PIN
    int "Radio 0 — RF-switch RX-enable GPIO (-1 if none)"
    default -1
    depends on LORA_COUNT > 0
    help
        Optional external antenna RF switch driven by two MCU GPIOs
        (Module::setRfSwitchPins). Leave both at -1 if the board has no
        switch or the chip drives it internally (e.g. SX126x DIO2 above).
config LORA0_RFSW_TX_PIN
    int "Radio 0 — RF-switch TX-enable GPIO (-1 if none)"
    default -1
    depends on LORA_COUNT > 0
choice
    prompt "Radio 0 — chip"
    default LORA0_RADIO_SX1262
    depends on LORA_COUNT > 0
    help
        The LoRa chip on this slot. All RadioLib LoRa parts are supported:
        SX126x (sub-GHz), SX127x/RFM9x (sub-GHz), SX128x (2.4 GHz), and the
        LR11x0 / LR2021 families. The driver dispatches begin() per family;
        the runtime path is shared. SX128x needs 2.4 GHz freq/bandwidth
        values (the LoRa settings expose them).
    config LORA0_RADIO_SX1261
        bool "SX1261 (SX126x, sub-GHz)"
    config LORA0_RADIO_SX1262
        bool "SX1262 (SX126x, sub-GHz)"
    config LORA0_RADIO_SX1268
        bool "SX1268 (SX126x, sub-GHz)"
    config LORA0_RADIO_LLCC68
        bool "LLCC68 (SX126x, sub-GHz)"
    config LORA0_RADIO_SX1272
        bool "SX1272 (SX127x / RFM9x)"
    config LORA0_RADIO_SX1276
        bool "SX1276 (SX127x / RFM95)"
    config LORA0_RADIO_SX1277
        bool "SX1277 (SX127x / RFM97)"
    config LORA0_RADIO_SX1278
        bool "SX1278 (SX127x / RFM96/98)"
    config LORA0_RADIO_SX1280
        bool "SX1280 (SX128x, 2.4 GHz)"
    config LORA0_RADIO_SX1281
        bool "SX1281 (SX128x, 2.4 GHz)"
    config LORA0_RADIO_SX1282
        bool "SX1282 (SX128x, 2.4 GHz)"
    config LORA0_RADIO_LR1110
        bool "LR1110 (LR11x0)"
    config LORA0_RADIO_LR1120
        bool "LR1120 (LR11x0)"
    config LORA0_RADIO_LR1121
        bool "LR1121 (LR11x0)"
    config LORA0_RADIO_LR2021
        bool "LR2021"
endchoice
config LORA0_CHIP_ID
    int
    depends on LORA_COUNT > 0
    default 0 if LORA0_RADIO_SX1261
    default 1 if LORA0_RADIO_SX1262
    default 2 if LORA0_RADIO_SX1268
    default 3 if LORA0_RADIO_LLCC68
    default 4 if LORA0_RADIO_SX1272
    default 5 if LORA0_RADIO_SX1276
    default 6 if LORA0_RADIO_SX1277
    default 7 if LORA0_RADIO_SX1278
    default 8 if LORA0_RADIO_SX1280
    default 9 if LORA0_RADIO_SX1281
    default 10 if LORA0_RADIO_SX1282
    default 11 if LORA0_RADIO_LR1110
    default 12 if LORA0_RADIO_LR1120
    default 13 if LORA0_RADIO_LR1121
    default 14 if LORA0_RADIO_LR2021
    default 1

